// FxLMS核心算法模块
// 功能：128阶FxLMS滤波器，支持定步长/变步长切换，权重实时更新
`timescale 1ns / 1ps

module fxlms_core(
    input           sys_clk,
    input           sys_rst_n,
    input           sample_en,
    input   signed [15:0] x_input,      // 原始参考信号，Q4.12
    input   signed [15:0] xf_input,     // 滤波后xf信号，Q4.12
    input   signed [15:0] error_input,  // 误差信号，Q4.12
    input           step_mode_sel,       // 0=定步长，1=变步长
    output  reg signed [15:0] fxlms_output // FxLMS控制输出，Q4.12
);

// ==================== 参数定义 ====================
parameter   FILTER_ORDER    = 128;          // 滤波器阶数L=128
parameter   MU_FIXED        = 38'sd137439;  // 定步长5e-7，量化为5e-7*2^38
parameter   MU_MIN          = 38'sd13744;   // 最小步长5e-8
parameter   MU_MAX          = 38'sd1374390;  // 最大步长5e-6
parameter   SHIFT_BIT       = 6'd38;         // 步长右移位数
parameter   WINDOW_LEN      = 256;            // 变步长滑动窗口长度

// ==================== 内部信号定义 ====================
// 参考信号与xf信号缓冲区
reg signed [15:0]  x_buffer [FILTER_ORDER-1:0];
reg signed [15:0]  xf_buffer [FILTER_ORDER-1:0];
// 滤波器权重系数，Q16.16
reg signed [31:0]  w_coeff [FILTER_ORDER-1:0];
// 步长信号
reg signed [37:0]  mu_current;
// 误差包络与变步长计算
reg signed [31:0]  err_env;
reg signed [15:0]  err_abs;
// FIR滤波输出与权重更新临时变量
reg signed [47:0]  fir_acc;
integer i;

// ==================== 参考信号与xf信号缓冲区更新 ====================
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        for(i=0; i<FILTER_ORDER; i=i+1) begin
            x_buffer[i] <= 16'sd0;
            xf_buffer[i] <= 16'sd0;
        end
    end
    else if(sample_en) begin
        // 移位寄存器更新，最新数据放在0地址
        for(i=FILTER_ORDER-1; i>0; i=i-1) begin
            x_buffer[i] <= x_buffer[i-1];
            xf_buffer[i] <= xf_buffer[i-1];
        end
        x_buffer[0] <= x_input;
        xf_buffer[0] <= xf_input;
    end
end

// ==================== 变步长计算：误差包络平滑+指数映射 ====================
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        err_abs <= 16'sd0;
        err_env <= 32'sd0;
        mu_current <= MU_FIXED;
    end
    else if(sample_en) begin
        // 误差绝对值计算
        err_abs <= error_input[15] ? -error_input : error_input;
        // 一阶低通平滑误差包络 err_env = 0.9995*err_env + 0.0005*err_abs
        err_env <= (32'sd9995 * err_env + 32'sd5 * err_abs) / 32'sd10000;
        
        // 步长模式选择
        if(!step_mode_sel) begin
            // 定步长模式
            mu_current <= MU_FIXED;
        end
        else begin
            // 变步长模式：mu = mu_min + (mu_max - mu_min)*exp(-err_env/2.0)
            // 简化指数映射，FPGA可实现的分段线性近似
            if(err_env < 32'sd2048) begin // 误差小，步长拉满
                mu_current <= MU_MAX;
            end
            else if(err_env > 32'sd8192) begin // 误差大，步长缩到最小
                mu_current <= MU_MIN;
            end
            else begin // 线性过渡
                mu_current <= MU_MAX - ((err_env - 32'sd2048) * (MU_MAX - MU_MIN)) / 32'sd6144;
            end
        end
    end
end

// ==================== FIR滤波输出计算 ====================
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        fir_acc <= 48'sd0;
        fxlms_output <= 16'sd0;
    end
    else if(sample_en) begin
        // 乘累加计算FIR输出：y = sum(w_coeff[i] * x_buffer[i])
        fir_acc = 48'sd0;
        for(i=0; i<FILTER_ORDER; i=i+1) begin
            fir_acc = fir_acc + ((w_coeff[i] * x_buffer[i]) >>> 12); // Q16.16 * Q4.12 → 右移12位对齐
        end
        // 输出限幅，Q4.12格式
        fxlms_output <= fir_acc[31:16] > 16'sd7 ? 16'sd32767 : 
                        fir_acc[31:16] < -16'sd8 ? -16'sd32768 : 
                        fir_acc[27:12]; // 截取Q4.12有效位
    end
end

// ==================== FxLMS权重更新 ====================
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        for(i=0; i<FILTER_ORDER; i=i+1) begin
            w_coeff[i] <= 32'sd0; // 权重初始化为0
        end
    end
    else if(sample_en) begin
        // 权重更新公式：w(n+1) = w(n) - mu * error(n) * xf(n)
        for(i=0; i<FILTER_ORDER; i=i+1) begin
            // 梯度计算：mu * error * xf
            w_coeff[i] <= w_coeff[i] - ((mu_current * error_input * xf_buffer[i]) >>> SHIFT_BIT);
        end
    end
end

endmodule