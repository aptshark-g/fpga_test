// 窄带谐波抑制模块（谐波刺客）
// 功能：针对2/3次谐波进行自适应抵消，匹配MATLAB的谐波抑制逻辑
`timescale 1ns / 1ps

module harmonic_suppress(
    input           sys_clk,
    input           sys_rst_n,
    input           sample_en,
    input           en,                 // 模块使能
    input   [15:0]  current_phase,      // 基频相位输入
    input   signed [15:0] error_input,  // 误差信号
    input   signed [15:0] xf_input,     // 滤波后xf信号
    output  reg signed [15:0] harm_output // 谐波抑制输出
);

parameter   MU_HARM = 32'sd2147; // 谐波步长5e-4，量化值
parameter   SHIFT_HARM = 6'd22;

// 谐波权重系数
reg signed [31:0]  w_harm [3:0];
// 2/3次谐波正余弦参考信号
reg signed [15:0]  x_harm [3:0];
reg [31:0]         phase_2x, phase_3x;

// 谐波参考信号生成
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        phase_2x <= 32'd0;
        phase_3x <= 32'd0;
        x_harm[0] <= 16'sd0;
        x_harm[1] <= 16'sd0;
        x_harm[2] <= 16'sd0;
        x_harm[3] <= 16'sd0;
    end
    else if(sample_en && en) begin
        // 2倍频/3倍频相位计算
        phase_2x <= current_phase * 2;
        phase_3x <= current_phase * 3;
        // 正余弦信号生成（简化版，可替换为CORDIC IP）
        x_harm[0] <= $sin(phase_2x) * 16'sd4096; // sin(2θ) Q4.12
        x_harm[1] <= $cos(phase_2x) * 16'sd4096; // cos(2θ) Q4.12
        x_harm[2] <= $sin(phase_3x) * 16'sd4096; // sin(3θ) Q4.12
        x_harm[3] <= $cos(phase_3x) * 16'sd4096; // cos(3θ) Q4.12
    end
end

// 谐波输出计算
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n || !en) begin
        harm_output <= 16'sd0;
    end
    else if(sample_en) begin
        harm_output <= ((w_harm[0] * x_harm[0]) + (w_harm[1] * x_harm[1]) + 
                        (w_harm[2] * x_harm[2]) + (w_harm[3] * x_harm[3])) >>> 12;
    end
end

// 谐波权重更新
always @(posedge sys_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        for(integer i=0; i<4; i=i+1) begin
            w_harm[i] <= 32'sd0;
        end
    end
    else if(sample_en && en) begin
        for(integer i=0; i<4; i=i+1) begin
            w_harm[i] <= w_harm[i] - ((MU_HARM * error_input * x_harm[i]) >>> SHIFT_HARM);
        end
    end
end

endmodule